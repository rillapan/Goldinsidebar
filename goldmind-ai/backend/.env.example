# ═══════════════════════════════════════════════════
# SINYAL COHIBA — Backend Environment Variables
# ═══════════════════════════════════════════════════

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/goldmind_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Xendit Payment Gateway
XENDIT_SECRET_KEY=xnd_development_xxxxxxxxxxxx
XENDIT_CALLBACK_TOKEN=your-xendit-callback-token
XENDIT_WEBHOOK_URL=https://yourdomain.com/api/webhooks/xendit

# Anthropic Claude API
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# Twelve Data API
TWELVE_DATA_API_KEY=your-twelve-data-api-key
TWELVE_DATA_WS_URL=wss://ws.twelvedata.com/v1/quotes/price

# News API
NEWS_API_KEY=your-newsapi-key

# Finnhub
FINNHUB_API_KEY=your-finnhub-api-key

# GoldAPI (spot price widget)
GOLD_API_KEY=your-goldapi-key

# WhatsApp (Fonnte)
FONNTE_API_KEY=your-fonnte-api-key
FONNTE_DEVICE_TOKEN=your-fonnte-device-token

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHANNEL_ID=@goldmind_signals

# Email (SMTP)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@goldmind.ai
