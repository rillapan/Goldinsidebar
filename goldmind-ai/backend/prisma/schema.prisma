generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(uuid())
  supabase_id    String?       @unique @map("supabase_id")
  email          String        @unique
  name           String
  phone          String
  telegramId          String?       @unique @map("telegram_id")
  telegramUsername    String?       @map("telegram_username")
  telegramConnected   Boolean       @default(false) @map("telegram_connected")
  telegramSettings    Json?         @map("telegram_settings")
  telegramVerifyToken String?       @unique @map("telegram_verify_token")
  role                UserRole      @default(MEMBER)
  status              UserStatus    @default(PENDING)
  activeDeviceId      String?       @map("active_device_id")
  lastLoginAt         DateTime?     @map("last_login_at")
  lastLoginIp         String?       @map("last_login_ip")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  chatSessions   ChatSession[]
  memberships    Membership[]
  transactions   Transaction[]
  journals       TradingJournal[]

  @@map("users")
}

model Membership {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  startDate     DateTime     @map("start_date")
  endDate       DateTime     @map("end_date")
  isActive      Boolean      @default(true) @map("is_active")
  transactionId String?      @unique @map("transaction_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([endDate])
  @@map("memberships")
}

model Signal {
  id         String       @id @default(uuid())
  type       SignalType
  status     SignalStatus @default(ACTIVE)
  entryPrice Float        @map("entry_price")
  stopLoss   Float        @map("stop_loss")
  takeProfit Float        @map("take_profit")
  currentSl  Float?       @map("current_sl")
  partialTp  Float?       @map("partial_tp")
  confidence Int
  timeframe  String       @default("M15")
  reasoning  String
  exitPrice  Float?       @map("exit_price")
  pnlPips    Float?       @map("pnl_pips")
  closedAt   DateTime?    @map("closed_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([status])
  @@map("signals")
}

model Transaction {
  id               String            @id @default(uuid())
  userId           String            @map("user_id")
  xenditInvoiceId  String            @unique @map("xendit_invoice_id")
  xenditInvoiceUrl String?           @map("xendit_invoice_url")
  amount           Float
  currency         String            @default("IDR")
  paymentMethod    PaymentMethod?    @map("payment_method")
  status           TransactionStatus @default(PENDING)
  description      String?
  paidAt           DateTime?         @map("paid_at")
  expiredAt        DateTime?         @map("expired_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  membership       Membership?
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("transactions")
}

model DailyBias {
  id           String        @id @default(uuid())
  date         DateTime      @unique @db.Date
  direction    BiasDirection
  confidence   Int
  reasoning    String
  newsData     Json?         @map("news_data")
  indicators   Json?
  isPublished  Boolean       @default(false) @map("is_published")
  publishedAt  DateTime?     @map("published_at")
  waSent       Boolean       @default(false) @map("wa_sent")
  telegramSent Boolean       @default(false) @map("telegram_sent")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([date])
  @@map("daily_bias")
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    String        @map("user_id")
  title     String?
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id           String      @id @default(uuid())
  sessionId    String      @map("session_id")
  role         String
  content      String
  priceContext Json?       @map("price_context")
  createdAt    DateTime    @default(now()) @map("created_at")
  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

enum UserRole {
  MEMBER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum SignalType {
  BUY
  SELL
  HOLD
}

enum SignalStatus {
  ACTIVE
  TP_HIT
  SL_HIT
  PARTIAL_TP
  CANCELLED
  MANUAL_CLOSE
}

enum BiasDirection {
  BUY
  SELL
  WAIT
}

enum TransactionStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  QRIS
  VIRTUAL_ACCOUNT
  EWALLET
  BANK_TRANSFER
}

model TradingJournal {
  id         String        @id @default(uuid())
  userId     String        @map("user_id")
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  instrument String        @default("XAUUSD")
  lotSize    Float         @map("lot_size")
  entryPrice Float         @map("entry_price")
  takeProfit Float?        @map("take_profit")
  stopLoss   Float?        @map("stop_loss")
  result     JournalResult
  pnlUsd     Float         @default(0) @map("pnl_usd")
  notes      String?
  tradeDate  DateTime      @default(now()) @map("trade_date")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@index([userId])
  @@index([tradeDate])
  @@map("trading_journals")
}

enum JournalResult {
  WIN
  LOSS
  BE
}
