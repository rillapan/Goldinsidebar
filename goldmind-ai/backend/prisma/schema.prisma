// ═══════════════════════════════════════════════════════════
// GoldMind AI — Prisma Schema (PostgreSQL)
// Tabel: users, memberships, signals, transactions, 
//        daily_bias, chat_sessions, chat_messages
// ═══════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUM DEFINITIONS ────────────────────────────────────

enum UserRole {
  MEMBER
  ADMIN
}

enum UserStatus {
  PENDING    // Baru registrasi, belum bayar
  ACTIVE     // Membership aktif
  EXPIRED    // Masa aktif habis
  SUSPENDED  // Diblokir admin
}

enum SignalType {
  BUY
  SELL
  HOLD
}

enum SignalStatus {
  ACTIVE        // Sinyal masih berjalan
  TP_HIT        // Take Profit tercapai
  SL_HIT        // Stop Loss tercapai
  PARTIAL_TP    // Partial Take Profit
  CANCELLED     // Dibatalkan
  MANUAL_CLOSE  // Ditutup manual
}

enum BiasDirection {
  BUY
  SELL
  WAIT
}

enum TransactionStatus {
  PENDING    // Menunggu pembayaran
  PAID       // Sudah dibayar
  EXPIRED    // Invoice kedaluwarsa
  FAILED     // Gagal
  REFUNDED   // Dikembalikan
}

enum PaymentMethod {
  QRIS
  VIRTUAL_ACCOUNT
  EWALLET
  BANK_TRANSFER
}

// ─── USERS ───────────────────────────────────────────────
// Tabel utama user. Menyimpan data profil, status membership,
// dan role (MEMBER / ADMIN).

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String       @map("password_hash")
  name           String
  phone          String       // Nomor WhatsApp
  telegramId     String?      @map("telegram_id")
  role           UserRole     @default(MEMBER)
  status         UserStatus   @default(PENDING)
  
  // Session & Security
  activeDeviceId String?      @map("active_device_id") // Untuk deteksi multi-login
  lastLoginAt    DateTime?    @map("last_login_at")
  lastLoginIp    String?      @map("last_login_ip")
  
  // Timestamps
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  
  // Relations
  memberships    Membership[]
  transactions   Transaction[]
  chatSessions   ChatSession[]
  
  @@map("users")
}

// ─── MEMBERSHIPS ─────────────────────────────────────────
// Mencatat setiap periode membership user.
// Setiap pembayaran sukses = 1 row baru (30 hari).

model Membership {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  
  startDate    DateTime     @map("start_date")
  endDate      DateTime     @map("end_date")     // start_date + 30 hari
  isActive     Boolean      @default(true) @map("is_active")
  
  // Link ke transaksi yang mengaktifkan membership ini
  transactionId String?     @unique @map("transaction_id")
  
  createdAt    DateTime     @default(now()) @map("created_at")
  
  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction  Transaction? @relation(fields: [transactionId], references: [id])
  
  @@index([userId])
  @@index([endDate])
  @@map("memberships")
}

// ─── SIGNALS ─────────────────────────────────────────────
// Sinyal trading XAUUSD yang dihasilkan AI Signal Engine.
// Setiap sinyal memiliki entry, SL, TP, confidence, reasoning.

model Signal {
  id           String       @id @default(uuid())
  
  type         SignalType               // BUY / SELL / HOLD
  status       SignalStatus @default(ACTIVE)
  
  entryPrice   Float        @map("entry_price")
  stopLoss     Float        @map("stop_loss")
  takeProfit   Float        @map("take_profit")
  
  // Partial TP / SL Update tracking
  currentSl    Float?       @map("current_sl")   // SL yang sudah digeser
  partialTp    Float?       @map("partial_tp")    // Level partial TP
  
  confidence   Int                      // 0-100
  timeframe    String       @default("M15")
  reasoning    String       @db.Text    // Penjelasan AI
  
  // Hasil akhir
  exitPrice    Float?       @map("exit_price")
  pnlPips      Float?       @map("pnl_pips")     // Profit/Loss dalam pips
  closedAt     DateTime?    @map("closed_at")
  
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  
  @@index([createdAt])
  @@index([status])
  @@map("signals")
}

// ─── TRANSACTIONS ────────────────────────────────────────
// Setiap transaksi pembayaran via Xendit.
// Menyimpan invoice ID, metode bayar, dan status.

model Transaction {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  
  // Xendit Data
  xenditInvoiceId String            @unique @map("xendit_invoice_id")
  xenditInvoiceUrl String?          @map("xendit_invoice_url")
  
  amount          Float                          // Dalam Rupiah
  currency        String            @default("IDR")
  paymentMethod   PaymentMethod?    @map("payment_method")
  status          TransactionStatus @default(PENDING)
  
  // Metadata
  description     String?
  paidAt          DateTime?         @map("paid_at")
  expiredAt       DateTime?         @map("expired_at")
  
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  
  // Relations
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership      Membership?
  
  @@index([userId])
  @@index([status])
  @@map("transactions")
}

// ─── DAILY BIAS ──────────────────────────────────────────
// Market Bias harian yang dihasilkan AI setiap pukul 07.00 WIB.

model DailyBias {
  id           String        @id @default(uuid())
  
  date         DateTime      @unique @db.Date  // Satu bias per hari
  direction    BiasDirection           // BUY / SELL / WAIT
  confidence   Int                     // 0-100
  reasoning    String        @db.Text  // Penjelasan AI dalam Bahasa Indonesia
  
  // Sumber data yang digunakan
  newsData     Json?         @map("news_data")    // Array berita yang di-fetch
  indicators   Json?                              // Data indikator saat analisa
  
  // Status distribusi
  isPublished  Boolean       @default(false) @map("is_published")
  publishedAt  DateTime?     @map("published_at")
  waSent       Boolean       @default(false) @map("wa_sent")
  telegramSent Boolean       @default(false) @map("telegram_sent")
  
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  
  @@index([date])
  @@map("daily_bias")
}

// ─── CHAT SESSIONS ───────────────────────────────────────
// Sesi percakapan AI Chat Assistant per member.
// AI mempertahankan konteks dalam satu sesi.

model ChatSession {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  
  title        String?                 // Auto-generated dari pertanyaan pertama
  isActive     Boolean       @default(true) @map("is_active")
  
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  
  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]
  
  @@index([userId])
  @@map("chat_sessions")
}

// ─── CHAT MESSAGES ───────────────────────────────────────
// Pesan individual dalam sesi chat.

model ChatMessage {
  id           String        @id @default(uuid())
  sessionId    String        @map("session_id")
  
  role         String                  // 'user' | 'assistant'
  content      String        @db.Text
  
  // Metadata (data harga yang disertakan saat prompt)
  priceContext Json?         @map("price_context")
  
  createdAt    DateTime      @default(now()) @map("created_at")
  
  // Relations
  session      ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId])
  @@map("chat_messages")
}
